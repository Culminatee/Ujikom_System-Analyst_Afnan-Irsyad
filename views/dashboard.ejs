<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Inventaris</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('./partials/navbar') %>
  <div class="container mt-4">
    <h5>👋 Selamat datang, <strong><%= user.nama %></strong>
      <span class="badge bg-primary"><%= user.role %></span>
    </h5>

    <!-- Statistik (petugas & admin) -->
    <% if (user.role === 'petugas' || user.role === 'admin') { %>
    <div class="row mt-3 mb-4">
      <div class="col-md-3">
        <div class="card text-white bg-secondary text-center p-3">
          <h6>Total Peminjaman</h6>
          <h3><%= stats.total_peminjaman %></h3>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-warning text-center p-3">
          <h6>Menunggu</h6>
          <h3><%= stats.menunggu %></h3>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-primary text-center p-3">
          <h6>Sedang Dipinjam</h6>
          <h3><%= stats.dipinjam %></h3>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card text-white bg-success text-center p-3">
          <h6>Dikembalikan</h6>
          <h3><%= stats.dikembalikan %></h3>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Rekap Barang (petugas & admin) -->
    <% if (user.role === 'petugas' || user.role === 'admin') { %>
    <h6 class="mt-2" style="font-size: 1.5rem;">Rekap Inventaris Barang</h6>
    <table class="table table-bordered table-striped table-hover table-sm">
      <thead class="table-dark">
        <tr>
          <th>No</th>
          <th>Kode Barang</th>
          <th>Nama Barang</th>
          <th>Stok</th>
          <th>Tgl Ditambahkan</th>
        </tr>
      </thead>
      <tbody>
        <% barang.forEach((b, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= b.kode_barang %></td>
          <td><%= b.nama_barang %></td>
          <td>
            <span class="badge <%= b.jumlah > 0 ? 'bg-success' : 'bg-danger' %>">
              <%= b.jumlah %> unit
            </span>
          </td>
          <td><%= new Date(b.created_at).toLocaleDateString('id-ID') %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

    <!-- Peminjaman Terbaru (semua role) -->
    <h6 class="mt-4" style="font-size: 1.5rem;">
      <% if (user.role === 'staf') { %>
        Peminjaman Saya (5 Terbaru)
      <% } else { %>
        Peminjaman Terbaru
      <% } %>
    </h6>
    <table class="table table-bordered table-hover table-sm">
      <thead class="table-dark">
        <tr>
          <th>No</th>
          <% if (user.role !== 'staf') { %><th>Peminjam</th><% } %>
          <th>Barang</th>
          <th>Jumlah</th>
          <th>Tgl Pinjam</th>
          <th>Tgl Kembali</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (peminjaman.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted">Belum ada data peminjaman</td></tr>
        <% } %>
        <% peminjaman.forEach((p, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <% if (user.role !== 'staf') { %><td><%= p.nama_peminjam %></td><% } %>
          <td><%= p.nama_barang %></td>
          <td><%= p.jumlah %> unit</td>
          <td><%= new Date(p.tgl_pinjam).toLocaleDateString('id-ID') %></td>
          <td><%= new Date(p.tgl_kembali_rencana).toLocaleDateString('id-ID') %></td>
          <td>
            <% if (p.status === 'menunggu') { %>
              <span class="badge bg-warning text-dark">Menunggu</span>
            <% } else if (p.status === 'disetujui') { %>
              <span class="badge bg-primary">Dipinjam</span>
            <% } else if (p.status === 'dikembalikan') { %>
              <span class="badge bg-success">Dikembalikan</span>
            <% } else { %>
              <span class="badge bg-danger">Ditolak</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Log Aktivitas (admin only) -->
    <% if (user.role === 'admin') { %>
    <h6 class="mt-4" style="font-size: 1.5rem;">Log Aktivitas Terbaru</h6>
    <table class="table table-bordered table-striped table-hover table-sm">
      <thead class="table-dark">
        <tr>
          <th>No</th>
          <th>Pengguna</th>
          <th>Aksi</th>
          <th>Keterangan</th>
          <th>Waktu</th>
        </tr>
      </thead>
      <tbody>
        <% if (log.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted">Belum ada log</td></tr>
        <% } %>
        <% log.forEach((l, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= l.nama_user || '-' %></td>
          <td><span class="badge bg-secondary"><%= l.aksi %></span></td>
          <td><%= l.keterangan %></td>
          <td><small><%= new Date(l.created_at).toLocaleString('id-ID') %></small></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>

  </div>
</body>
</html>