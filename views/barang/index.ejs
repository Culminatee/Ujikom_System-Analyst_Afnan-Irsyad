<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Data Barang</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5>Data Barang</h5>
      <% if (user.role === 'petugas' || user.role === 'admin') { %>
        <a href="/barang/create" class="btn btn-primary btn-sm">+ Tambah Barang</a>
      <% } %>
    </div>

    <!-- Search -->
    <form action="/barang" method="GET" class="mb-3">
      <div class="input-group">
        <input type="text" name="search" class="form-control" placeholder="Cari nama/kode barang..." value="<%= search %>">
        <button class="btn btn-outline-secondary">Cari</button>
        <a href="/barang" class="btn btn-outline-danger">Reset</a>
      </div>
    </form>

    <table class="table table-bordered table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>No</th>
          <th>Kode Barang</th>
          <th>Nama Barang</th>
          <th>Jumlah</th>
          <th>Tgl Ditambahkan</th>
          <% if (user.role === 'petugas' || user.role === 'admin') { %>
            <th>Aksi</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (barang.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted">Tidak ada data barang</td></tr>
        <% } %>
        <% barang.forEach((b, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><%= b.kode_barang %></td>
          <td><%= b.nama_barang %></td>
          <td><span class="badge bg-success"><%= b.jumlah %> unit</span></td>
          <td><%= new Date(b.created_at).toLocaleDateString('id-ID') %></td>
          <% if (user.role === 'petugas' || user.role === 'admin') { %>
          <td>
            <a href="/barang/<%= b.id %>/edit" class="btn btn-warning btn-sm">Edit</a>
            <form action="/barang/<%= b.id %>?_method=DELETE" method="POST" style="display:inline">
              <button class="btn btn-danger btn-sm" onclick="return confirm('Yakin hapus barang ini?')">Hapus</button>
            </form>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>