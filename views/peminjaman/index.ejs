<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Peminjaman</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5>Data Peminjaman</h5>
      <a href="/peminjaman/create" class="btn btn-primary btn-sm">+ Ajukan Peminjaman</a>
    </div>

    <table class="table table-bordered table-hover">
      <thead class="table-dark">
        <tr>
          <th>No</th>
          <th>Kode</th>
          <th>Peminjam</th>
          <th>Barang</th>
          <th>Jumlah</th>
          <th>Tgl Pinjam</th>
          <th>Tgl Kembali</th>
          <th>Status</th>
          <% if (user.role === 'petugas' || user.role === 'admin') { %>
            <th>Aksi</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (peminjaman.length === 0) { %>
          <tr><td colspan="9" class="text-center text-muted">Tidak ada data peminjaman</td></tr>
        <% } %>
        <% peminjaman.forEach((p, i) => { %>
        <tr>
          <td><%= i + 1 %></td>
          <td><small><%= p.kode_pinjam %></small></td>
          <td><%= p.nama_peminjam %></td>
          <td><%= p.nama_barang %></td>
          <td><%= p.jumlah %> unit</td>
          <td><%= new Date(p.tgl_pinjam).toLocaleDateString('id-ID') %></td>
          <td><%= new Date(p.tgl_kembali_rencana).toLocaleDateString('id-ID') %></td>
          <td>
            <% if (p.status === 'menunggu') { %>
              <span class="badge bg-warning text-dark">Menunggu</span>
            <% } else if (p.status === 'disetujui') { %>
              <span class="badge bg-primary">Disetujui</span>
            <% } else if (p.status === 'dikembalikan') { %>
              <span class="badge bg-success">Dikembalikan</span>
            <% } else { %>
              <span class="badge bg-danger">Ditolak</span>
            <% } %>
          </td>
          <% if (user.role === 'petugas' || user.role === 'admin') { %>
          <td>
            <% if (p.status === 'menunggu') { %>
              <form action="/peminjaman/<%= p.id %>/setujui" method="POST" style="display:inline">
                <button class="btn btn-success btn-sm" onclick="return confirm('Setujui peminjaman ini?')">Setujui</button>
              </form>
              <form action="/peminjaman/<%= p.id %>/tolak" method="POST" style="display:inline">
                <button class="btn btn-danger btn-sm" onclick="return confirm('Tolak peminjaman ini?')">Tolak</button>
              </form>
            <% } else if (p.status === 'disetujui') { %>
              <form action="/peminjaman/<%= p.id %>/kembalikan" method="POST" style="display:inline">
                <button class="btn btn-info btn-sm" onclick="return confirm('Proses pengembalian?')">Kembalikan</button>
              </form>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>