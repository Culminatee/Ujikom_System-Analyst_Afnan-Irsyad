<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Ajukan Peminjaman</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('../partials/navbar') %>
  <div class="container mt-4" style="max-width: 600px;">
    <h5>Ajukan Peminjaman</h5>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>
    <form action="/peminjaman" method="POST" class="card p-4 shadow-sm mt-3">
      <div class="mb-3">
        <label class="form-label">Barang</label>
        <select name="barang_id" class="form-select" required>
          <option value="">-- Pilih Barang --</option>
          <% barang.forEach(b => { %>
            <option value="<%= b.id %>"><%= b.nama_barang %> (Stok: <%= b.jumlah %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label">Jumlah</label>
        <input type="number" name="jumlah" class="form-control" min="1" value="1" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Tanggal Pinjam</label>
        <input type="date" name="tgl_pinjam" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Rencana Tanggal Kembali</label>
        <input type="date" name="tgl_kembali_rencana" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Catatan <small class="text-muted">(opsional)</small></label>
        <textarea name="catatan" class="form-control" rows="2"></textarea>
      </div>
      <div class="d-flex gap-2">
        <button class="btn btn-primary">Ajukan</button>
        <a href="/peminjaman" class="btn btn-secondary">Batal</a>
      </div>
    </form>
  </div>
</body>
</html>